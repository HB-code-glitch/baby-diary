rules_version = '2';
//
// firestore.rules — BABY DIARY
//
// 설계 원칙 (F-RULES 보안 강화):
//   1. 가족 멤버(uid가 members 맵에 있음)만 자신의 가족 문서와 이벤트 접근 가능
//   2. 이벤트 doc은 create-only (update/delete 불가 — append-only 아키텍처 보장)
//   3. invites/{code} 컬렉션: 초대코드 직접 get()만 허용 (list 불가)
//      → 인증된 사용자만 정확한 코드로 get 가능, 열거 공격 불가
//   4. families list 완전 차단 → 아기 이름/멤버/초대코드 열거 불가
//   5. families self-join: auth.uid를 members에 추가하는 update만 허용
//      (변경된 키가 members뿐이고, 기존 멤버 제거 없이 본인만 추가하는 경우)
//   6. rev 감소 방지 / 하드 삭제 방지: events create-only이므로 자동 보장
//
// ─── 보안 감사 소견 ────────────────────────────────────────────────────────
// [PASS] members 멤버만 가족 데이터 접근 — uid 기반 맵 체크
// [PASS] 이벤트 create-only — update/delete 규칙 없음
// [PASS] families list 차단 — 아기 이름/초대코드 열거 불가
// [PASS] invites list 차단 — 코드 열거 불가 (get만 허용)
// [PASS] self-join 검증 — members diff가 auth.uid 추가뿐임을 확인
// [INFO] 브루트포스: 36^6 ≈ 2.2억 경우. 인증된 사용자만 get() 가능.
//        Spark 무료 플랜 읽기 쿼터(50k/day)로 실질적 브루트포스 불가능.
// ──────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 사용자 개인 문서 (클라우드 identity truth) ─────────────────────────
    // users/{uid}: { familyId } — 클라우드 정체성 진실 소스
    // 자신의 doc만 read/write 가능.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── 초대 코드 컬렉션 ───────────────────────────────────────────────────
    // invites/{code}: { familyId, createdAt, code_check }
    // code_check is redundant but lets rules verify the doc id matches
    match /invites/{code} {
      // 인증된 사용자만 정확한 코드로 직접 get 가능 (list 완전 차단)
      allow get: if request.auth != null;
      allow list: if false;

      // 인증된 사용자가 본인 가족을 만들 때 생성 (createFamily 배치에서 호출)
      // code_check == document id 로 간단히 검증
      allow create: if request.auth != null
        && request.resource.data.code_check == code
        && request.resource.data.familyId is string;

      // 수정/삭제 불가
      allow update, delete: if false;
    }

    // ── 가족 문서 ──────────────────────────────────────────────────────────
    match /families/{familyId} {

      // 멤버 여부 확인 함수 (가족 문서에 직접 접근하는 경우)
      function isMember() {
        return request.auth != null
          && resource.data.members[request.auth.uid] != null;
      }

      // get: 멤버만 허용 (초대코드 조회는 이제 invites 컬렉션에서 처리)
      allow get: if isMember();

      // list: 완전 차단 (아기 이름, 멤버, 초대코드 열거 방지)
      allow list: if false;

      // 새 가족 생성: 로그인한 사용자, 자신이 members에 포함되어 있어야 함
      allow create: if request.auth != null
        && request.resource.data.members[request.auth.uid] != null
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() == 6;

      // 가족 정보 수정 (기존 멤버만):
      //   (a) 일반 정보 수정 (이미 멤버인 경우)
      //   (b) self-join: 변경된 키가 members뿐이고, auth.uid가 새로 추가되는 경우
      allow update: if isMember()
        || (
          request.auth != null
          // 변경된 최상위 키가 members뿐임
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          // 본인 uid가 새로 추가됨
          && request.resource.data.members[request.auth.uid] != null
          // 기존 멤버가 제거되지 않음 (기존 members는 그대로 포함)
          && resource.data.members.keys().toSet().difference(
               request.resource.data.members.keys().toSet()
             ).size() == 0
        );

      // 삭제는 허용하지 않음
      allow delete: if false;

      // ── 이벤트 서브컬렉션 ─────────────────────────────────────────────
      match /events/{eventDocId} {

        // 읽기: 가족 멤버만 (get으로 family doc을 조회하여 확인)
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;

        // 쓰기: create-only (멤버만), update/delete 불가
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/families/$(familyId)).data.members[request.auth.uid] != null;

        // update/delete 명시적 거부 (create-only 보장)
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
