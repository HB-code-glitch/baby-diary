{
  "name": "baby-diary",
  "version": "0.3.6",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "build": "npm run typecheck && tsc -p tsconfig.node.json && vite build",
    "build:win": "npm run build && electron-builder --win && powershell -ExecutionPolicy Bypass -File scripts/update-shortcut.ps1",
    "build:mac": "npm run build && electron-builder --mac",
    "test": "vitest run",
    "test:e2e": "node scripts/mac-e2e.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/zen-maru-gothic": "^5.2.8",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "firebase": "^10.12.2",
    "i18next": "^26.3.6",
    "lucide-react": "^0.396.0",
    "pretendard": "^1.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9",
    "recharts": "^2.12.7",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.39",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.family.babydiary",
    "productName": "Baby Diary",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "universal"
          ]
        }
      ]
    },
    "nsis": {
      "shortcutName": "베이비 다이어리"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "HB-code-glitch",
        "repo": "baby-diary-releases",
        "releaseType": "release"
      }
    ]
  }
}
